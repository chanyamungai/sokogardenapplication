<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#6780"
    tools:context=".Signin">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sokogarden"
        android:textSize="47sp"
        android:fontFamily="cursive"
        android:textAlignment="center"
        android:textStyle="bold|italic"
        android:textColor="#F5FFF5"
        android:background="@drawable/shape"
        android:padding="12dp"/>

    <!--      Below is a card view-->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="10dp"
        app:cardElevation="10dp"
        android:layout_margin="12dp"
        android:padding="10dp">

<!--        Below is a liner layout that aligns content vertically-->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="10dp">

<!--            Below is the edit text of email-->

            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="📧Enter your Email Address"
                android:textColorHint="#000"
                android:textSize="20sp"
                android:textColor="#070707"
                android:inputType="textEmailAddress"
                android:fontFamily="sans-serif"
                android:id="@+id/email"
                android:layout_margin="8dp"
                android:background="#F5FFF5"
                android:padding="7dp"/>

<!--            Below is the edit text for password-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="🔑 Enter your password"
                android:textColorHint="#000"
                android:textSize="20sp"
                android:textColor="#070707"
                android:fontFamily="sans-serif"
                android:id="@+id/password"
                android:inputType="textPassword"
                android:layout_margin="8dp"
                android:background="#F5FFF5"
                android:padding="7dp"/>



<!--            Below is the edit text for signin button-->
            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=" Sign In 🍀"
                android:textStyle="italic"
                android:textSize="25sp"
                android:padding="10dp"
                android:layout_marginLeft="50dp"
                android:layout_marginRight="50dp"
                android:backgroundTint="#FF6EC7"
                android:textColor="#000"
                android:layout_marginTop="22dp"
                android:id="@+id/signinbtn"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Dont have an account? Signup"
                android:textAlignment="center"
                android:textColor="#000"
                android:textSize="23sp"
                android:layout_marginTop="12dp"
                android:id="@+id/signuptxt"
                android:fontFamily="sans-serif-black"/>




        </LinearLayout>

    </androidx.cardview.widget.CardView>


</LinearLayout>